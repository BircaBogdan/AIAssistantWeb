@model List<AIAssistant.Core.Models.Message>

<style>

	.chat-container {
		max-width: 900px;
		margin: auto;
		display: flex;
		flex-direction: column;
		height: 70vh;
	}

	.chat-box {
		flex: 1;
		overflow-y: auto;
		border: 1px solid #ddd;
		padding: 20px;
		border-radius: 10px;
		background: #fafafa;
	}

	.message-user {
		text-align: right;
		margin: 10px 0;
	}

	.message-ai {
		text-align: left;
		margin: 10px 0;
	}

	.bubble-user {
		display: inline-block;
		background: #007bff;
		color: white;
		padding: 10px 15px;
		border-radius: 15px;
		max-width: 70%;
	}

	.bubble-ai {
		display: inline-block;
		background: #e9ecef;
		padding: 10px 15px;
		border-radius: 15px;
		max-width: 70%;
	}

	.chat-controls {
		margin-top: 10px;
	}

	pre {
		background: #1e1e1e;
		color: #ffffff;
		padding: 15px;
		border-radius: 10px;
		overflow-x: auto;
		font-family: Consolas, monospace;
		font-size: 14px;
		line-height: 1.5;
	}

	code {
		background: #2d2d2d;
		color: #00ffcc;
		padding: 3px 6px;
		border-radius: 5px;
	}

</style>

<div class="chat-container">

	<h2>AI Assistant</h2>

	@if (ViewBag.Alert != null)
	{
		<div class="alert alert-warning">
			@ViewBag.Alert
		</div>
	}

	<div id="chatBox" class="chat-box">

		@foreach (var msg in Model)
		{
			<div class="@(msg.IsUser ? "message-user" : "message-ai")">
				<div class="@(msg.IsUser ? "bubble-user" : "bubble-ai")">
					@Html.Raw(msg.Text)
				</div>
			</div>
		}

	</div>

	<div class="chat-controls">

		<select id="assistantName" class="form-control mb-2">
			@if (ViewBag.Profiles != null)
			{
				foreach (var profile in ViewBag.Profiles)
				{
					<option value="@profile.Name">@profile.Name</option>
				}
			}
		</select>

		<div class="input-group">
			<input id="messageInput" class="form-control" placeholder="Type a message...">
			<button onclick="sendMessage()" class="btn btn-primary">
				Send
			</button>
		</div>

		<button onclick="regenerate()" class="btn btn-warning" style="margin-top:10px;">
			Regenerate
		</button>

		<form method="post" asp-action="Clear" style="margin-top:5px;">
			<button type="submit" class="btn btn-danger">Clear Chat</button>
		</form>

	</div>

</div>

<!-- COUNTER -->
<div style="margin-top:20px; text-align:center;">
	<b>
		Total Messages Processed:
		<span id="msgCount">@AIAssistant.Core.Services.GlobalMetrics.Instance.TotalMessages</span>
	</b>
</div>

<!-- TOAST -->
<div id="toast" style="
	position: fixed;
	bottom: 20px;
	right: 20px;
	background: #ffc107;
	padding: 15px 20px;
	border-radius: 10px;
	display: none;
	font-weight: bold;
	z-index: 999;
"></div>

<script>

	const chatBox = document.getElementById("chatBox")

	function scrollBottom() {
		chatBox.scrollTop = chatBox.scrollHeight
	}

	function showToast(message) {
		const toast = document.getElementById("toast")
		toast.innerText = message
		toast.style.display = "block"

		setTimeout(() => {
			toast.style.display = "none"
		}, 3000)
	}

	document.getElementById("messageInput")
	.addEventListener("keypress", function (e) {
		if (e.key === "Enter") {
			e.preventDefault()
			sendMessage()
		}
	})

	async function updateCounter() {
		const res = await fetch("/Chat/GetMessageCount")
		const count = await res.text()

		const counter = document.getElementById("msgCount")
		if (counter) {
			counter.innerText = count
		}
	}

	async function sendMessage() {

		const message = document.getElementById("messageInput").value
		const assistant = document.getElementById("assistantName").value

		if (!message) return

		const userDiv = document.createElement("div")
		userDiv.className = "message-user"
		userDiv.innerHTML = `<div class="bubble-user">${message}</div>`
		chatBox.appendChild(userDiv)

		document.getElementById("messageInput").value = ""

		const loadingDiv = document.createElement("div")
		loadingDiv.className = "message-ai"
		loadingDiv.innerHTML = `<div class="bubble-ai">Typing...</div>`
		chatBox.appendChild(loadingDiv)

		scrollBottom()

		const response = await fetch("/Chat/Stream", {
			method: "POST",
			headers: {
				"Content-Type": "application/x-www-form-urlencoded"
			},
			body: `message=${encodeURIComponent(message)}&assistantName=${assistant}`
		})

		const reader = response.body.getReader()
		const decoder = new TextDecoder()

		let result = ""

		chatBox.removeChild(loadingDiv)

		const aiDiv = document.createElement("div")
		aiDiv.className = "message-ai"

		const bubble = document.createElement("div")
		bubble.className = "bubble-ai"

		aiDiv.appendChild(bubble)
		chatBox.appendChild(aiDiv)

		while (true) {

			const { done, value } = await reader.read()
			if (done) break

			const chunk = decoder.decode(value)

			// TOAST LOGIC
			if (chunk.includes("Mesaje rămase: 15")) {
				showToast("Atenție: Mai ai doar 15 mesaje disponibile pentru astăzi!")
			}
			if (chunk.includes("Mesaje rămase: 10")) {
				showToast("Atenție: Mai ai doar 10 mesaje disponibile pentru astăzi!")
			}
			if (chunk.includes("Mesaje rămase: 5")) {
				showToast("Atenție: Mai ai doar 5 mesaje disponibile pentru astăzi!")
			}

			result += chunk

			if (result.includes("===DECORATED===")) {
				const parts = result.split("===DECORATED===")
				bubble.innerHTML = parts[1]
			} else {
				bubble.innerText = result
			}

			scrollBottom()
		}

		await updateCounter()
		scrollBottom()
	}

	scrollBottom()

		async function regenerate() {

		const response = await fetch("/Chat/Regenerate", {
			method: "POST"
		})

		const reader = response.body.getReader()
		const decoder = new TextDecoder()

		let result = ""

		const aiDiv = document.createElement("div")
		aiDiv.className = "message-ai"

		const bubble = document.createElement("div")
		bubble.className = "bubble-ai"

		aiDiv.appendChild(bubble)
		chatBox.appendChild(aiDiv)

		while (true) {

			const { done, value } = await reader.read()
			if (done) break

			const chunk = decoder.decode(value)

			result += chunk

			if (result.includes("===DECORATED===")) {
				const parts = result.split("===DECORATED===")
				bubble.innerHTML = parts[1]
			} else {
				bubble.innerText = result
			}

			scrollBottom()
		}
	}

</script>