@model List<AIAssistant.Core.Models.Message>

<style>

	.chat-container {
		max-width: 900px;
		margin: auto;
		display: flex;
		flex-direction: column;
		height: 70vh;
	}

	.chat-box {
		flex: 1;
		overflow-y: auto;
		border: 1px solid #ddd;
		padding: 20px;
		border-radius: 10px;
		background: #fafafa;
	}

	.message-user {
		text-align: right;
		margin: 10px 0;
	}

	.message-ai {
		text-align: left;
		margin: 10px 0;
	}

	.bubble-user {
		display: inline-block;
		background: #007bff;
		color: white;
		padding: 10px 15px;
		border-radius: 15px;
		max-width: 70%;
	}

	.bubble-ai {
		display: inline-block;
		background: #e9ecef;
		padding: 10px 15px;
		border-radius: 15px;
		max-width: 70%;
	}

	.chat-controls {
		margin-top: 10px;
	}

	/* CODE BLOCK STYLE */
	pre {
		background: #1e1e1e;
		color: #dcdcdc;
		padding: 10px;
		border-radius: 8px;
		overflow-x: auto;
		font-family: monospace;
	}

	code {
		background: #eee;
		padding: 2px 4px;
		border-radius: 4px;
	}

</style>

<div class="chat-container">

	<h2>AI Assistant</h2>

	<div id="chatBox" class="chat-box">

		@foreach (var msg in Model)
		{
			<div class="@(msg.IsUser ? "message-user" : "message-ai")">

				<div class="@(msg.IsUser ? "bubble-user" : "bubble-ai")">
					@Html.Raw(msg.Text) <!-- 🔥 IMPORTANT -->
				</div>

			</div>
		}

	</div>

	<div class="chat-controls">

		<select id="assistantName" class="form-control mb-2">

			@if (ViewBag.Profiles != null)
			{
				foreach (var profile in ViewBag.Profiles)
				{
					<option value="@profile.Name">@profile.Name</option>
				}
			}

		</select>

		<div class="input-group">

			<input id="messageInput" class="form-control" placeholder="Type a message...">

			<button onclick="sendMessage()" class="btn btn-primary">
				Send
			</button>

		</div>

	</div>

</div>

<script>

	const chatBox = document.getElementById("chatBox")

	function scrollBottom() {
		chatBox.scrollTop = chatBox.scrollHeight
	}

	// ENTER = SEND
	document.getElementById("messageInput")
	.addEventListener("keypress", function (e) {
		if (e.key === "Enter") {
			e.preventDefault()
			sendMessage()
		}
	})

	async function sendMessage() {

		const message = document.getElementById("messageInput").value
		const assistant = document.getElementById("assistantName").value

		if (!message) return

		// USER MESSAGE
		const userDiv = document.createElement("div")
		userDiv.className = "message-user"
		userDiv.innerHTML = `<div class="bubble-user">${message}</div>`
		chatBox.appendChild(userDiv)

		document.getElementById("messageInput").value = ""

		// LOADING
		const loadingDiv = document.createElement("div")
		loadingDiv.className = "message-ai"
		loadingDiv.innerHTML = `<div class="bubble-ai">Typing...</div>`
		chatBox.appendChild(loadingDiv)

		scrollBottom()

		const response = await fetch("/Chat/Stream", {
			method: "POST",
			headers: {
				"Content-Type": "application/x-www-form-urlencoded"
			},
			body: `message=${encodeURIComponent(message)}&assistantName=${assistant}`
		})

		const reader = response.body.getReader()
		const decoder = new TextDecoder()

		let result = ""

		// REMOVE LOADING
		chatBox.removeChild(loadingDiv)

		const aiDiv = document.createElement("div")
		aiDiv.className = "message-ai"

		const bubble = document.createElement("div")
		bubble.className = "bubble-ai"

		aiDiv.appendChild(bubble)
		chatBox.appendChild(aiDiv)

		while (true) {

			const { done, value } = await reader.read()
			if (done) break

			const chunk = decoder.decode(value)

			result += chunk

			bubble.innerHTML = result

			scrollBottom()
		}

		scrollBottom()
	}

	scrollBottom()

</script>