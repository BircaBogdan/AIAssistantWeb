@{
    ViewData["Title"] = "Create Assistant Profile";
}

<div class="container mt-4">

    <h2>Create Assistant Profile</h2>

    <div class="card mt-3">
        <div class="card-body">

            <form asp-controller="Home" asp-action="CreateProfile" method="post">

                <!-- NAME -->
                <div class="form-group mb-3">
                    <label>Name</label>

                    <input type="text"
                           name="name"
                           class="form-control"
                           placeholder="Example: Math Assistant"
                           required />
                </div>

                <!-- SYSTEM PROMPT -->
                <div class="form-group mb-3">
                    <label>Base System Prompt</label>

                    <input type="text"
                           name="systemPrompt"
                           class="form-control"
                           placeholder="Example: You are a helpful assistant"
                           required />
                </div>

                <!-- COMPOSITE: MODULES -->
                <div class="form-group mb-3">
                    <label>Modular Behavior (Composite Pattern)</label>

                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="modules"
                               value="RO" />

                        <label class="form-check-label">
                            Răspunde doar în Română
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="modules"
                               value="MD" />

                        <label class="form-check-label">
                            Formatează codul în Markdown
                        </label>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="modules"
                               value="SARCASTIC" />

                        <label class="form-check-label">
                            Fii sarcastic
                        </label>
                    </div>
                </div>

                <!-- 🔌 ADAPTER: AI PROVIDER -->
                <div class="form-group mb-3">
                    <label>AI Provider (Adapter Pattern)</label>

                    <select name="provider" class="form-control">
                        <option value="Ollama">Ollama</option>
                        <option value="FakeAI">Fake AI</option>
                    </select>
                </div>

                <!-- TEMPERATURE -->
                <div class="form-group mb-3">
                    <label>Temperature (0 - 1)</label>

                    <input type="number"
                           name="temperature"
                           step="0.1"
                           min="0"
                           max="1"
                           value="0.5"
                           class="form-control"
                           required />
                </div>

                <!-- STRATEGY -->
                <div class="form-group mb-3">
                    <label>Response Style</label>

                    <select name="strategy" class="form-control">
                        <option value="formal">
                            Formal Assistant
                        </option>

                        <option value="friendly">
                            Friendly Assistant
                        </option>
                    </select>
                </div>

                <!-- PLUGIN -->
                <div class="form-check mb-3">

                    <input type="checkbox"
                           class="form-check-input"
                           name="plugins"
                           value="Ollama"
                           checked />

                    <label class="form-check-label">
                        Enable Ollama Plugin
                    </label>

                </div>

                <!-- BUTTONS -->
                <button type="submit" class="btn btn-success">
                    Create Profile
                </button>

                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>
    </div>

</div>